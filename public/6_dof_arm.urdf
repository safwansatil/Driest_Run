<?xml version="1.0"?>
<!--
  stylus_arm v2: 6-DOF serial arm + 1-DOF stylus pitch (7 actuated joints total).

  Changes from v1
  ===============
  * All link radii increased ~25% (chunkier profile), hubs scaled to match.
  * link_4 and link_6 shortened: 0.25 m -> 0.15 m (masses reduced accordingly).
  * Stylus is no longer fixed: it now pitches about Y, the same axis family
    as joint_2 / joint_3 / joint_5 (joint "stylus_pitch").

  Joint layout:
      J1  base yaw      (Z)   L1 = 0.25
      J2  shoulder      (Y)   L2 = 0.25
      J3  elbow         (Y)   L3 = 0.25
      J4  forearm roll  (Z)   L4 = 0.15
      J5  wrist pitch   (Y)   L5 = 0.25
      J6  tool roll     (Z)   L6 = 0.15
      J7  stylus pitch  (Y)   stylus = 0.126

  Physically valid: full solid-cylinder inertia tensors about each COM,
  tapering masses, joint position/effort/velocity limits, damping + friction,
  collision geometry on every body.
-->
<robot name="stylus_arm">

  <!-- ======================= Materials ======================= -->
  <material name="graphite"><color rgba="0.22 0.24 0.27 1.0"/></material>
  <material name="slate"><color rgba="0.35 0.38 0.42 1.0"/></material>
  <material name="amber"><color rgba="0.95 0.60 0.10 1.0"/></material>
  <material name="steel"><color rgba="0.75 0.77 0.80 1.0"/></material>
  <material name="tip_black"><color rgba="0.05 0.05 0.05 1.0"/></material>

  <!-- ======================= Base ======================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry><cylinder radius="0.100" length="0.060"/></geometry>
      <material name="graphite"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.058" rpy="0 0 0"/>
      <geometry><cylinder radius="0.086" length="0.008"/></geometry>
      <material name="amber"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry><cylinder radius="0.100" length="0.060"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.011200" iyy="0.011200" izz="0.020000" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======================= J1: base yaw (Z) ======================= -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.060" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="60.0" velocity="2.5"/>
    <dynamics damping="0.8" friction="0.4"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.068"/></geometry>
      <material name="amber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.250"/></geometry>
      <material name="graphite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.250"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.011929" iyy="0.011929" izz="0.003025" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======================= J2: shoulder pitch (Y) ======================= -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.250" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="60.0" velocity="2.5"/>
    <dynamics damping="0.8" friction="0.4"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.062" length="0.130"/></geometry>
      <material name="amber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.050" length="0.250"/></geometry>
      <material name="slate"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.050" length="0.250"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="1.6"/>
      <inertia ixx="0.009333" iyy="0.009333" izz="0.002000" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======================= J3: elbow pitch (Y) ======================= -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.250" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6180" upper="2.6180" effort="40.0" velocity="3.0"/>
    <dynamics damping="0.6" friction="0.3"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.115"/></geometry>
      <material name="amber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.044" length="0.250"/></geometry>
      <material name="graphite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.044" length="0.250"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="1.3"/>
      <inertia ixx="0.007400" iyy="0.007400" izz="0.001258" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======================= J4: forearm roll (Z), short link ======================= -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.250" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="25.0" velocity="3.5"/>
    <dynamics damping="0.4" friction="0.2"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.050"/></geometry>
      <material name="amber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.150"/></geometry>
      <material name="slate"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.150"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <mass value="0.7"/>
      <inertia ixx="0.001565" iyy="0.001565" izz="0.000505" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======================= J5: wrist pitch (Y) ======================= -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.150" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="15.0" velocity="4.0"/>
    <dynamics damping="0.3" friction="0.15"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.043" length="0.090"/></geometry>
      <material name="amber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.034" length="0.250"/></geometry>
      <material name="graphite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.034" length="0.250"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.004398" iyy="0.004398" izz="0.000462" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======================= J6: tool roll (Z), short link ======================= -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.250" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="4.5"/>
    <dynamics damping="0.2" friction="0.1"/>
  </joint>

  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.040"/></geometry>
      <material name="amber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.030" length="0.150"/></geometry>
      <material name="slate"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.030" length="0.150"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.000840" iyy="0.000840" izz="0.000180" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ======= J7: stylus pitch (Y) — same axis family as J2/J3/J5 ======= -->
  <joint name="stylus_pitch" type="revolute">
    <parent link="link_6"/>
    <child link="stylus"/>
    <origin xyz="0 0 0.150" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="8.0" velocity="5.0"/>
    <dynamics damping="0.15" friction="0.08"/>
  </joint>

  <link name="stylus">
    <!-- pitch hub, transverse like the other Y joints -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.022" length="0.056"/></geometry>
      <material name="amber"/>
    </visual>
    <!-- collet -->
    <visual>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.024"/></geometry>
      <material name="tip_black"/>
    </visual>
    <!-- barrel -->
    <visual>
      <origin xyz="0 0 0.080" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.100"/></geometry>
      <material name="steel"/>
    </visual>
    <!-- nib -->
    <visual>
      <origin xyz="0 0 0.132" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
      <material name="tip_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.068" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.136"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000123" iyy="0.000123" izz="0.0000050" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- TCP frame at the stylus nib -->
  <joint name="stylus_tip_frame" type="fixed">
    <parent link="stylus"/>
    <child link="stylus_tip"/>
    <origin xyz="0 0 0.137" rpy="0 0 0"/>
  </joint>

  <link name="stylus_tip"/>

</robot>